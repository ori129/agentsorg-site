---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
  type?: 'website' | 'article';
  publishedDate?: string;
}

const { title, description, ogImage, canonical, type = 'website', publishedDate } = Astro.props;
const pageUrl = canonical || Astro.url.href;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={pageUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content={type} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={pageUrl} />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta property="og:site_name" content="AgentsOrg" />

  <!-- Twitter -->
  <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}

  {publishedDate && <meta property="article:published_time" content={publishedDate} />}

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/favicon-192.png" />

  <!-- Schema.org: Organization -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "AgentsOrg",
    "url": "https://agentsorg.ai",
    "logo": "https://agentsorg.ai/logo.svg",
    "description": "Open-source AI Transformation Intelligence platform for enterprise ChatGPT governance",
    "sameAs": [
      "https://github.com/ori129/agentsorg"
    ],
    "founder": {
      "@type": "Person",
      "name": "Ori Simantov",
      "url": "https://agentsorg.ai/about"
    }
  })} />

  <!-- Schema.org: SoftwareApplication -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "AgentsOrg",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Docker",
    "description": "Open-source AI Transformation Intelligence platform for enterprise ChatGPT governance",
    "url": "https://agentsorg.ai",
    "license": "https://opensource.org/licenses/Apache-2.0",
    "author": {
      "@type": "Organization",
      "name": "AgentsOrg",
      "url": "https://agentsorg.ai"
    },
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  })} />
</head>
<body class="min-h-screen flex flex-col">
  <Nav />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
</body>
</html>

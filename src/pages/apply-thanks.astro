---
import Base from '../layouts/Base.astro';
---
<Base
  title="Application Received — AgentsOrg Advisors"
  description="Thank you for applying to the AgentsOrg AI Transformation Advisors directory."
>
  <section class="pt-40 pb-24 px-6">
    <div class="max-w-2xl mx-auto text-center">
      <div class="w-16 h-16 rounded-full bg-green/10 border border-green/30 flex items-center justify-center mx-auto mb-8">
        <svg class="w-8 h-8 text-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
      </div>
      <h1 class="text-4xl font-black mb-4">Application Received</h1>
      <p class="text-text-muted text-xl mb-8 leading-relaxed">
        Thanks for applying to the AgentsOrg Advisor Directory. We review applications weekly and will be in touch within a few days.
      </p>
      <div class="p-6 rounded-2xl border border-border bg-surface text-left mb-8">
        <h3 class="font-semibold mb-3">While you wait:</h3>
        <ul class="space-y-2 text-text-muted text-sm">
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            <a href="https://github.com/ori129/agentsorg" target="_blank" class="text-accent hover:underline">Star the repo</a> — helps with visibility
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            <a href="https://github.com/ori129/agentsorg#quick-start" target="_blank" class="text-accent hover:underline">Deploy AgentsOrg locally</a> — explore it before your first client engagement
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            <a href="https://github.com/ori129/agentsorg/discussions" target="_blank" class="text-accent hover:underline">Join GitHub Discussions</a> — connect with the community
          </li>
        </ul>
      </div>
      <a href="/advisors" class="inline-flex items-center gap-2 text-accent hover:underline">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to Advisor Directory
      </a>
    </div>
  </section>
</Base>

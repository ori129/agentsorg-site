        <a href="https://github.com/ori129/agentsorg/issues" target="_blank"
          class="p-5 sm:p-7 rounded-2xl border border-border bg-bg hover:border-accent/30 transition-all group text-center">
          <div class="w-10 h-10 rounded-xl bg-amber/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-5 h-5 text-amber" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="font-semibold mb-2 group-hover:text-amber transition-colors">Report a Bug</h3>
          <p class="text-text-muted text-sm">We respond within 48 hours.</p>

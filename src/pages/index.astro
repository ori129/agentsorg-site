        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 relative">
          <a href="/advisors" class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl bg-accent text-white font-semibold hover:bg-accent/90 transition-all text-sm">

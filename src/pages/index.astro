  <!-- ─── FAQ ──────────────────────────────────────────────────── -->
  <section class="py-14 md:py-24 px-4 sm:px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-bold mb-6 md:mb-10 text-center">FAQ</h2>
      <div class="space-y-3">
        {faqs.map(faq => (
          <details class="group p-4 sm:p-6 rounded-2xl border border-border bg-surface hover:border-accent/30 transition-colors">
            <summary class="cursor-pointer font-semibold flex items-center justify-between gap-4">
              {faq.q}
              <svg class="w-5 h-5 text-text-dim group-open:rotate-180 transition-transform shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <p class="mt-4 text-text-muted text-sm leading-relaxed">{faq.a}</p>
          </details>
        ))}
      </div>

      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqs.map(f => ({
          "@type": "Question",
          "name": f.q,
          "acceptedAnswer": { "@type": "Answer", "text": f.a }
        }))
      })} />
    </div>
  </section>

  <!-- ─── FINAL CTA ─────────────────────────────────────────────── -->
  <section class="py-14 md:py-24 px-4 sm:px-6 bg-surface">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">See your GPT portfolio in 5 minutes.</h2>
      <p class="text-text-muted text-base sm:text-lg mb-8">No API key. No signup. Demo mode included.</p>

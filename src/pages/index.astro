        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl bg-accent text-white font-semibold hover:bg-accent/90 transition-all hover:shadow-xl hover:shadow-accent/25 text-sm mb-6"
      >
        Try demo — no API key, no signup
      </a>
      <div class="p-5 rounded-2xl border border-border bg-bg font-mono text-left text-sm overflow-x-auto">
        <div class="text-text-dim text-xs mb-2 uppercase tracking-wider">Or self-host in minutes</div>
        <div><span class="text-text-dim select-none">$ </span><span class="text-text">git clone https://github.com/ori129/agentsorg.git</span></div>
        <div><span class="text-text-dim select-none">$ </span><span class="text-text">cd agentsorg && make up</span></div>
        <div class="text-green mt-2">✓ Ready at http://localhost:3000</div>
      </div>
    </div>
  </section>

</Base>

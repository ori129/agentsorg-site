---
import Base from '../layouts/Base.astro';

const kpis = ['Risk', 'Quality', 'ROI', 'Sophistication', 'Business Process', 'Audience', 'Integrations', 'Output Type', 'Adoption Friction'];

const dashboardSections = [
  {
    label: 'Overview',
    color: 'accent',
    desc: 'Portfolio health at a glance — KPI strip, creation velocity, GPT-level drill-downs by builder, department, maturity, process, and output type.',
  },
  {
    label: 'Governance',
    color: 'red',
    desc: 'Three lenses on risk: flagged GPTs by severity, semantic duplicate clusters, and prompting quality distribution across the portfolio.',
    items: ['Risk Panel', 'Duplicates', 'Quality Scores'],
  },
  {
    label: 'Learning & Development',
    color: 'amber',
    desc: 'Composite builder scores surface your AI champions. LLM-driven course recommendations target actual gaps. Workshop tracking shows real improvement over time.',
    items: ['Recognition', 'Learning', 'Workshops'],
  },
  {
    label: 'Employee Portal',
    color: 'green',
    desc: 'Read-only GPT discovery for the entire org. Find the right GPT instead of building another duplicate.',
  },
];

const steps = [
  { num: '01', title: 'Clone & deploy', code: 'git clone https://github.com/ori129/agentsorg.git\ncd agentsorg && make up', desc: 'One command. Three containers. Your data never leaves your infrastructure.' },
  { num: '02', title: 'Connect or demo', desc: 'Enter your OpenAI Compliance API key — or flip on Demo mode. No API key needed to explore the full platform.' },
  { num: '03', title: 'Run the pipeline', desc: 'Fetch → Filter → Classify → Enrich → Embed → Store. Every Custom GPT scored across 9 semantic dimensions automatically.' },
  { num: '04', title: 'Act on intelligence', desc: 'Leader Dashboard surfaces risk, duplicates, quality gaps, and L&D opportunities. Employee Portal gives the org a place to discover what already exists.' },
];

const faqs = [
  {
    q: 'Is this affiliated with OpenAI?',
    a: 'No. Independent open-source project. Integrates with OpenAI\'s Compliance API, GPT API, and Embeddings API — not endorsed by OpenAI.',
  },
  {
    q: 'Does my GPT data leave my infrastructure?',
    a: 'Never. Fully self-hosted on your own PostgreSQL instance. API keys are encrypted at rest with Fernet before touching the database.',
  },
  {
    q: 'What do I actually need to run this?',
    a: 'Docker Desktop. That\'s it. Clone, run make up, and you\'re live at localhost:3000. Demo mode works without any OpenAI key.',
  },
  {
    q: 'How is this different from the OpenAI admin console?',
    a: 'The admin console shows you a list. AgentsOrg gives you intelligence — risk scores, quality grades, duplicate clusters, maturity tiers, builder recognition, and targeted learning recommendations per person.',
  },
  {
    q: 'Can I use this commercially?',
    a: 'Yes. Apache 2.0 — free for any use including production and commercial deployments. No restrictions, no license fees.',
  },
];
---

<Base
  title="AgentsOrg — AI Transformation Intelligence for Enterprise ChatGPT"
  description="Open-source governance platform for enterprise Custom GPTs. Connect to OpenAI's Compliance API. Discover, score, and act on every GPT in your workspace."
>

  <!-- ─── HERO ─────────────────────────────────────────────────── -->
  <section class="pt-32 pb-24 px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-accent/[0.07] via-transparent to-transparent pointer-events-none"></div>
    <div class="absolute top-32 left-1/2 -translate-x-1/2 w-[900px] h-[500px] bg-accent/[0.04] rounded-full blur-[140px] pointer-events-none"></div>

    <div class="max-w-4xl mx-auto text-center relative">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-border bg-surface text-xs text-text-muted mb-8 animate-fade-in">
        <span class="w-2 h-2 rounded-full bg-green animate-pulse"></span>
        Open Source &middot; Apache 2.0 &middot; Self-Hosted
      </div>

      <h1 class="text-5xl md:text-[4.5rem] font-black tracking-tight leading-[1.05] mb-7 animate-fade-in animate-delay-1">
        Your Custom GPTs.<br/>
        <span class="bg-gradient-to-r from-accent via-accent-2 to-violet bg-clip-text text-transparent">Finally governed.</span>
      </h1>

      <p class="text-xl md:text-2xl text-text-muted max-w-2xl mx-auto mb-10 animate-fade-in animate-delay-2 leading-relaxed">
        Connect to OpenAI's Compliance API. Discover every Custom GPT in your enterprise workspace. Score it, flag it, learn from it.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16 animate-fade-in animate-delay-3">
        <a
          href="https://github.com/ori129/agentsorg"
          target="_blank"
          class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl bg-accent text-white font-semibold hover:bg-accent/90 transition-all hover:shadow-xl hover:shadow-accent/25 text-sm"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          View on GitHub
        </a>
        <a
          href="https://github.com/ori129/agentsorg#quick-start"
          target="_blank"
          class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl border border-border bg-surface text-text font-semibold hover:border-accent/40 transition-all text-sm"
        >
          Try Demo Mode — no API key needed
        </a>
      </div>

      <!-- Stats strip -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto animate-fade-in animate-delay-4">
        {[
          { value: '9', label: 'Semantic KPIs per GPT' },
          { value: '6', label: 'Pipeline stages' },
          { value: '3', label: 'Views: Leader · Employee · Setup' },
          { value: '0', label: 'API key needed for demo' },
        ].map(s => (
          <div class="p-4 rounded-xl border border-border bg-surface text-center">
            <div class="text-2xl font-black text-accent mb-1">{s.value}</div>
            <div class="text-xs text-text-dim leading-tight">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── PROBLEM ───────────────────────────────────────────────── -->
  <section class="py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Your enterprise has a shadow AI problem</h2>
        <p class="text-text-muted text-lg max-w-xl mx-auto">
          ChatGPT Enterprise unlocked creation. Now hundreds of Custom GPTs exist with no visibility, no governance, and no measurement.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-5">
        {[
          {
            accent: 'red',
            title: 'Invisible portfolio',
            desc: 'Hundreds of Custom GPTs built across departments. No central inventory. No idea what handles sensitive data.',
          },
          {
            accent: 'amber',
            title: 'No governance',
            desc: 'No risk assessment. No quality standard. No duplicate detection. Compliance flying blind.',
          },
          {
            accent: 'accent',
            title: 'Wasted spend',
            desc: 'Three teams building the same GPT. No learning transfer. No ROI measurement on ChatGPT Enterprise.',
          },
        ].map(c => (
          <div class={`p-7 rounded-2xl border border-border bg-surface hover:border-${c.accent}/30 transition-colors`}>
            <h3 class="text-lg font-bold mb-3">{c.title}</h3>
            <p class="text-text-muted text-sm leading-relaxed">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── WHAT'S INSIDE ─────────────────────────────────────────── -->
  <section id="features" class="py-24 px-6 bg-surface">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">What's inside the platform</h2>
        <p class="text-text-muted text-lg max-w-xl mx-auto">
          Three views. One pipeline. Runs entirely on your infrastructure.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">

        <!-- Leader Dashboard — spans full width -->
        <div class="md:col-span-2 p-8 rounded-2xl border border-accent/20 bg-bg">
          <div class="flex items-center gap-3 mb-6">
            <span class="px-3 py-1 rounded-full text-xs font-semibold bg-accent/10 text-accent border border-accent/20">Leader Dashboard</span>
            <span class="text-text-dim text-sm">For AI leaders, ai-leader and system-admin roles</span>
          </div>
          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
            {[
              { name: 'Overview', color: 'accent', desc: 'Portfolio KPIs, creation velocity, drill-downs by builder · department · maturity · process · output type.' },
              { name: 'Risk Panel', color: 'red', desc: 'Every GPT flagged by risk level. Data exposure, compliance gaps, ungoverned builds — surfaced automatically.' },
              { name: 'Duplicates', color: 'violet', desc: 'pgvector semantic clustering finds GPTs solving the same problem, even when named differently.' },
              { name: 'Quality Scores', color: 'amber', desc: 'Prompting quality distribution across the portfolio. Spot the gap between your best and worst builders.' },
            ].map(item => (
              <div class={`p-5 rounded-xl border border-border bg-surface hover:border-${item.color}/30 transition-colors`}>
                <div class={`text-${item.color} text-xs font-semibold mb-2`}>{item.name}</div>
                <p class="text-text-muted text-xs leading-relaxed">{item.desc}</p>
              </div>
            ))}
          </div>

          <!-- L&D row -->
          <div class="mt-4 grid sm:grid-cols-3 gap-4">
            {[
              { name: 'Recognition', color: 'green', desc: 'Composite builder scores: quality 35% · adoption 25% · hygiene 25% · volume 15%.' },
              { name: 'Learning', color: 'green', desc: 'LLM recommends OpenAI Academy courses per builder based on actual KPI gaps — not generic training.' },
              { name: 'Workshops', color: 'green', desc: 'CRUD for sessions. Participant lists. GPT tagging. Time-based quality impact correlation.' },
            ].map(item => (
              <div class={`p-5 rounded-xl border border-border bg-surface hover:border-${item.color}/30 transition-colors`}>
                <div class={`text-${item.color} text-xs font-semibold mb-2`}>{item.name}</div>
                <p class="text-text-muted text-xs leading-relaxed">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Employee Portal -->
        <div class="p-8 rounded-2xl border border-border bg-bg">
          <div class="flex items-center gap-3 mb-4">
            <span class="px-3 py-1 rounded-full text-xs font-semibold bg-green/10 text-green border border-green/20">Employee Portal</span>
            <span class="text-text-dim text-sm">For all users</span>
          </div>
          <p class="text-text-muted text-sm leading-relaxed">
            Read-only GPT discovery for the entire org. Search and browse available Custom GPTs without accessing governance data. The first step toward reducing duplicate builds.
          </p>
        </div>

        <!-- 9 KPIs -->
        <div class="p-8 rounded-2xl border border-border bg-bg">
          <div class="text-xs text-text-dim uppercase tracking-wider mb-4">9 Semantic KPIs per GPT</div>
          <div class="flex flex-wrap gap-2">
            {kpis.map(kpi => (
              <span class="px-2.5 py-1 rounded-full text-xs border border-border bg-surface text-text-muted">{kpi}</span>
            ))}
          </div>
          <p class="text-text-dim text-xs mt-4 leading-relaxed">
            LLM-powered enrichment. Every GPT scored automatically — no manual tagging.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── HOW IT WORKS ──────────────────────────────────────────── -->
  <section id="how-it-works" class="py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Up and running in minutes</h2>
        <p class="text-text-muted text-lg">No SaaS signup. No data leaving your infrastructure. One command.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        {steps.map((s) => (
          <div class="p-7 rounded-2xl border border-border bg-surface relative overflow-hidden group hover:border-accent/30 transition-all">
            <span class="absolute top-5 right-6 text-5xl font-black text-border/40 group-hover:text-accent/10 transition-colors select-none">{s.num}</span>
            <h3 class="text-lg font-bold mb-3 relative">{s.title}</h3>
            {s.code && (
              <div class="font-mono text-xs bg-bg border border-border rounded-lg p-3 mb-3 text-text-muted whitespace-pre">{s.code}</div>
            )}
            <p class="text-text-muted text-sm leading-relaxed relative">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── ROADMAP ───────────────────────────────────────────────── -->
  <section id="roadmap" class="py-24 px-6 bg-surface">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Roadmap</h2>
        <p class="text-text-muted text-lg">What's live today and where we're going.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-5">
        <!-- Now -->
        <div class="p-7 rounded-2xl border border-accent/40 bg-bg">
          <div class="flex items-center gap-2 mb-5">
            <span class="w-2 h-2 rounded-full bg-green animate-pulse"></span>
            <span class="text-xs font-semibold text-green uppercase tracking-wider">Now — v1</span>
          </div>
          <ul class="space-y-2.5">
            {[
              'GPT discovery via Compliance API',
              '9-KPI semantic enrichment',
              'Risk flagging',
              'Semantic duplicate detection',
              'Builder recognition scores',
              'OpenAI Academy L&D recommendations',
              'Workshop tracking',
              'Demo mode — no API key needed',
              'Email-based auth & user roles',
            ].map(item => (
              <li class="flex items-start gap-2 text-sm text-text-muted">
                <svg class="w-4 h-4 text-green mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Coming -->
        <div class="p-7 rounded-2xl border border-border bg-bg">
          <div class="flex items-center gap-2 mb-5">
            <span class="w-2 h-2 rounded-full bg-violet"></span>
            <span class="text-xs font-semibold text-violet uppercase tracking-wider">Coming — v2</span>
          </div>
          <ul class="space-y-2.5">
            {[
              'Conversation analytics',
              'Usage-based adoption scoring',
              'Cost attribution per GPT',
              'Department benchmarking',
              'Automated portfolio reports',
              'GPT lifecycle tracking',
            ].map(item => (
              <li class="flex items-start gap-2 text-sm text-text-muted">
                <svg class="w-4 h-4 text-text-dim mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Vision -->
        <div class="p-7 rounded-2xl border border-border bg-bg">
          <div class="flex items-center gap-2 mb-5">
            <span class="w-2 h-2 rounded-full bg-text-dim"></span>
            <span class="text-xs font-semibold text-text-dim uppercase tracking-wider">Vision</span>
          </div>
          <ul class="space-y-2.5">
            {[
              'Slack & Teams alerts',
              'Auto-generated governance policies',
              'Builder certification',
              'Copilot Studio & Gemini support',
              'Cross-org benchmarking',
              'Enterprise SaaS offering',
            ].map(item => (
              <li class="flex items-start gap-2 text-sm text-text-dim">
                <svg class="w-4 h-4 text-text-dim/40 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── ADVISORS CTA ──────────────────────────────────────────── -->
  <section class="py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="p-12 rounded-3xl border border-accent/20 bg-gradient-to-br from-accent/5 via-surface to-accent-2/5 relative overflow-hidden text-center">
        <div class="absolute top-0 right-0 w-72 h-72 bg-accent/5 rounded-full blur-[120px] pointer-events-none"></div>
        <h2 class="text-3xl md:text-4xl font-bold mb-4 relative">AI Transformation Advisors</h2>
        <p class="text-text-muted text-lg mb-8 max-w-xl mx-auto relative leading-relaxed">
          Use AgentsOrg as your client assessment toolkit. Run a GPT portfolio audit in minutes. Get listed in our directory of 50+ advisors.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 relative">
          <a href="/advisors" class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl bg-accent text-white font-semibold hover:bg-accent/90 transition-all text-sm">
            View Advisor Directory
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
          <a href="/advisors#apply" class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl border border-border bg-surface text-text font-semibold hover:border-accent/50 transition-all text-sm">
            Apply to Join
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── OPEN SOURCE ───────────────────────────────────────────── -->
  <section class="py-16 px-6 bg-surface">
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-3 gap-5">
        <a href="https://github.com/ori129/agentsorg/blob/main/CONTRIBUTING.md" target="_blank"
          class="p-7 rounded-2xl border border-border bg-bg hover:border-accent/30 transition-all group text-center">
          <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
          </div>
          <h3 class="font-semibold mb-2 group-hover:text-accent transition-colors">Contribute</h3>
          <p class="text-text-muted text-sm">PRs welcome. Apache 2.0.</p>
        </a>
        <a href="https://github.com/ori129/agentsorg/discussions" target="_blank"
          class="p-7 rounded-2xl border border-border bg-bg hover:border-accent/30 transition-all group text-center">
          <div class="w-10 h-10 rounded-xl bg-violet/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-5 h-5 text-violet" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          </div>
          <h3 class="font-semibold mb-2 group-hover:text-violet transition-colors">Discuss</h3>
          <p class="text-text-muted text-sm">Questions, ideas, show & tell.</p>
        </a>
        <a href="https://github.com/ori129/agentsorg/issues" target="_blank"
          class="p-7 rounded-2xl border border-border bg-bg hover:border-accent/30 transition-all group text-center">
          <div class="w-10 h-10 rounded-xl bg-amber/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-5 h-5 text-amber" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="font-semibold mb-2 group-hover:text-amber transition-colors">Report a Bug</h3>
          <p class="text-text-muted text-sm">We respond within 48 hours.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ─── FAQ ──────────────────────────────────────────────────── -->
  <section class="py-24 px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-bold mb-10 text-center">FAQ</h2>
      <div class="space-y-3">
        {faqs.map(faq => (
          <details class="group p-6 rounded-2xl border border-border bg-surface hover:border-accent/30 transition-colors">
            <summary class="cursor-pointer font-semibold flex items-center justify-between gap-4">
              {faq.q}
              <svg class="w-5 h-5 text-text-dim group-open:rotate-180 transition-transform shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <p class="mt-4 text-text-muted text-sm leading-relaxed">{faq.a}</p>
          </details>
        ))}
      </div>

      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqs.map(f => ({
          "@type": "Question",
          "name": f.q,
          "acceptedAnswer": { "@type": "Answer", "text": f.a }
        }))
      })} />
    </div>
  </section>

  <!-- ─── FINAL CTA ─────────────────────────────────────────────── -->
  <section class="py-24 px-6 bg-surface">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Start in 5 minutes.</h2>
      <p class="text-text-muted text-lg mb-10">Demo mode included. No API key. No signup.</p>
      <div class="p-5 rounded-2xl border border-border bg-bg font-mono text-left mb-8 text-sm">
        <div><span class="text-text-dim select-none">$ </span><span class="text-text">git clone https://github.com/ori129/agentsorg.git</span></div>
        <div><span class="text-text-dim select-none">$ </span><span class="text-text">cd agentsorg && make up</span></div>
        <div class="text-green mt-2">✓ Ready at http://localhost:3000</div>
      </div>
      <a
        href="https://github.com/ori129/agentsorg"
        target="_blank"
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl bg-accent text-white font-semibold hover:bg-accent/90 transition-all hover:shadow-xl hover:shadow-accent/25 text-sm"

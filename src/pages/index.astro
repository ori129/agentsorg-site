---
import Base from '../layouts/Base.astro';

// Coverage matrix — what the Compliance API exposes and where we are
const apiSurface = [
  { name: 'Custom GPTs',         phase: 1, icon: '🤖' },
  { name: 'Projects',            phase: 1, icon: '📁' },
  { name: 'Conversations',       phase: 1, icon: '💬' },
  { name: 'Users & Behavior',    phase: 1, icon: '👥' },
  { name: 'Compliance Logs',     phase: 2, icon: '📋' },
  { name: 'Automations',         phase: 3, icon: '⚡' },
  { name: 'Canvases',            phase: 3, icon: '🎨' },
  { name: 'Memories',            phase: 3, icon: '🧠' },
  { name: 'Recordings',          phase: 3, icon: '🎙️' },
  { name: 'Codex Environments',  phase: 3, icon: '💻' },
  { name: 'Claude for Business', phase: 4, icon: '🟠' },
  { name: 'Gemini for Workspace',phase: 4, icon: '🔷' },
];

const faqs = [
  {
    q: 'What AI platforms does AgentsOrg support?',
    a: 'ChatGPT Enterprise and ChatGPT Team today, via OpenAI\'s Compliance API. Claude for Business (Anthropic) and Google Gemini for Workspace are on the roadmap. AgentsOrg started with ChatGPT Enterprise because OpenAI\'s Compliance API is the most mature enterprise data export available, but the governance problem applies across all enterprise AI platforms.',
  },
  {
    q: 'Is this affiliated with OpenAI?',
    a: 'No. Independent open-source project. Integrates with OpenAI\'s Compliance API, GPT API, and Embeddings API. Not endorsed by OpenAI.',
  },
  {
    q: 'Does my data leave my infrastructure?',
    a: 'Never. Fully self-hosted on your own PostgreSQL instance. API keys and OIDC secrets are Fernet-encrypted at rest. TOTP MFA secrets are encrypted before storage. Session cookies are HttpOnly + SameSite. Bearer tokens are restricted to API token type only — browser sessions cannot be replayed as API tokens.',
  },
  {
    q: 'Is this production-ready?',
    a: 'Yes. The full platform is live today: Custom GPT & Project portfolio discovery, risk flagging, standardization opportunity detection, quality and adoption scoring, builder recognition, L&D recommendations, conversation intelligence (ghost asset detection, per-user adoption insights, knowledge gap signals), workflow coverage analysis, and LLM-generated priority actions with a board-ready executive summary. Auth and security hardening is also complete: SSO via OIDC with hard enforcement, TOTP MFA, role-gated analytics, Fernet-encrypted secrets, and bearer token restrictions. Demo mode lets you explore everything without an API key.',
  },
  {
    q: 'How is this different from the OpenAI admin console?',
    a: 'The admin console is for managing users. AgentsOrg is for understanding what all those users are building: whether it\'s safe, redundant, worth the investment, and where AI demand is concentrating across the org. Different purpose entirely.',
  },
  {
    q: 'What\'s the ROI? How do I justify this to my CFO?',
    a: 'Three concrete levers: (1) Standardization of validated demand: when 6 teams independently build the same meeting-summary GPT, that is proof a shared certified solution should exist. One org standard replaces six fragmented rebuilds. (2) Risk prevention: one ungoverned GPT exposing sensitive data costs far more than the tool. Catching it early is the cheapest governance win available. (3) Targeted enablement: L&D spend goes to builders who actually need it, grounded in real skill gaps in their GPT output, not a blanket course rollout.',
  },
];
---

<Base
  title="AgentsOrg | Finally know what your team is building with ChatGPT"
  description="The open-source governance platform for ChatGPT Enterprise. Score every GPT and Project. Surface risks. Map workflow coverage. Identify your best builders. Every sync ends with a board-ready executive briefing."
>

  <!-- ─── HERO ─────────────────────────────────────────────────── -->
  <section class="pt-24 md:pt-32 pb-16 md:pb-24 px-4 sm:px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-accent/[0.07] via-transparent to-transparent pointer-events-none"></div>
    <div class="absolute top-32 left-1/2 -translate-x-1/2 w-[1000px] h-[500px] bg-accent/[0.04] rounded-full blur-[160px] pointer-events-none"></div>

    <div class="max-w-4xl mx-auto text-center relative">
      <div class="flex flex-wrap items-center justify-center gap-2 mb-8 animate-fade-in">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-green/30 bg-green/5 text-xs text-green font-semibold">
          <span class="w-2 h-2 rounded-full bg-green animate-pulse"></span>
          Production-ready today &middot; Open Source &middot; Apache 2.0
        </div>
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-accent/30 bg-accent/5 text-xs text-accent font-semibold">
          For AI Transformation Leaders in Enterprise
        </div>
      </div>

      <h1 class="text-4xl sm:text-5xl md:text-[4.5rem] font-black tracking-tight leading-[1.05] mb-7 animate-fade-in animate-delay-1">
        Finally know what your team<br/>
        <span class="bg-gradient-to-r from-accent via-accent-2 to-violet bg-clip-text text-transparent">is building with ChatGPT.</span>
      </h1>

      <p class="text-lg md:text-2xl text-text-muted max-w-2xl mx-auto mb-10 animate-fade-in animate-delay-2 leading-relaxed">
        Score every GPT and Project. Surface risks. Map workflow coverage. Detect where AI demand is concentrating across your org. Every sync ends with a board-ready executive briefing.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16 animate-fade-in animate-delay-3">
        <a
          href="https://github.com/ori129/agentsorg#quick-start"
          target="_blank"
          class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl bg-accent text-white font-semibold hover:bg-accent/90 transition-all hover:shadow-xl hover:shadow-accent/25 text-sm"
        >
          Try Demo. No API key, no signup.
        </a>
        <a
          href="https://github.com/ori129/agentsorg"
          target="_blank"
          class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl border border-border bg-surface text-text font-semibold hover:border-accent/40 transition-all text-sm"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          View on GitHub
        </a>
      </div>

      <!-- Compliance API surface map -->
      <div class="max-w-3xl mx-auto animate-fade-in animate-delay-4">
        <div class="text-xs text-text-dim uppercase tracking-wider mb-4">What AgentsOrg covers, today and on the roadmap</div>
        <div class="flex flex-wrap justify-center gap-2">
          {apiSurface.map(s => (
            <span class={`px-3 py-1.5 rounded-full text-xs border flex items-center gap-1.5 ${
              s.phase === 1
                ? 'border-accent/40 bg-accent/10 text-accent'
                : s.phase === 2
                ? 'border-violet/30 bg-violet/5 text-violet'
                : s.phase === 4
                ? 'border-amber/40 bg-amber/10 text-amber'
                : 'border-border bg-surface text-text-dim'
            }`}>
              {s.icon} {s.name}
              {s.phase === 1 && <span class="text-accent/60">✓</span>}
            </span>
          ))}
        </div>
        <div class="flex items-center justify-center gap-6 mt-4 text-xs text-text-dim">
          <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-accent inline-block"></span>Live</span>
          <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-violet inline-block"></span>Coming</span>
          <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-border inline-block"></span>Vision</span>
          <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-amber inline-block"></span>Multi-Platform Roadmap</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── SCREENSHOTS ─────────────────────────────────────────── -->
  <section class="py-14 md:py-20 px-4 sm:px-6 bg-surface">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-8 md:mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">See it in action</h2>
        <p class="text-text-muted text-lg max-w-xl mx-auto">Try the demo. No API key, no signup. Or explore the screens below.</p>
      </div>

      <!-- Tab bar -->
      <div class="flex flex-wrap justify-center gap-2 mb-6" id="ss-tabs">
        {[
          { id: 'home',         label: 'Home' },
          { id: 'portfolio',    label: 'Portfolio' },
          { id: 'adoption',     label: 'Adoption' },
          { id: 'workflows',    label: 'Workflows' },
          { id: 'build-signals',label: 'Build Signals' },
          { id: 'recognition',  label: 'Recognition' },
          { id: 'learning',     label: 'Courses' },
          { id: 'workshops',    label: 'Workshops' },
          { id: 'sync',         label: 'Sync' },
          { id: 'employee',     label: 'Employee Portal' },
          { id: 'journey',      label: 'Asset Journey' },
        ].map((tab, i) => (
          <button
            data-tab={tab.id}
            class={`ss-tab px-4 py-1.5 rounded-full text-xs font-semibold border transition-all ${i === 0 ? 'border-accent bg-accent/10 text-accent' : 'border-border bg-bg text-text-muted hover:border-accent/40 hover:text-text'}`}
          >
            {tab.label}
          </button>
        ))}
      </div>

      <!-- Screenshot panels -->
      <div class="relative rounded-2xl overflow-hidden border border-border shadow-2xl shadow-black/40">
        {[
          { id: 'home',          src: '/ss_home.png',          alt: 'Home: Quality vs Adoption quadrant with Champion, Hidden Gem, Scaled Risk, Retirement Candidate labels. Priority actions ranked by impact and effort. LLM executive summary.',                          caption: 'Champion vs Hidden Gem vs Scaled Risk. Know which GPTs to scale, promote, fix, or retire. From the first screen.' },
          { id: 'portfolio',     src: '/ss_portfolio.png',     alt: 'Portfolio: all GPTs with composite quality, adoption, and risk scores. Tabbed view for health, ghost assets, and risk flags.',                                                                         caption: '512 GPTs. Composite scores. Ghost assets. Risk flags. One view.' },
          { id: 'adoption',      src: '/ss_adoption.png',      alt: 'Adoption Intelligence: conversation counts, ghost asset alerts, drift signals, knowledge gap detection, top assets by usage, per-user insights.',                                                       caption: 'Conversation intelligence: who\'s actually using what, where usage is drifting, and where knowledge gaps are forming.' },
          { id: 'workflows',     src: '/ss_workflows.png',     alt: 'Workflows: covered business processes with conversation evidence, ghost coverage (built but unused), intent gaps (user demand with no dedicated asset). LLM reasoning and priority actions per workflow.', caption: 'Covered workflows, ghost coverage, and intent gaps. LLM reasoning included. Know where to build AI next.' },
          { id: 'build-signals', src: '/ss_build_signals.png', alt: 'Build Signals: semantic clustering detects when multiple teams independently built the same GPT. Groups by theme with estimated wasted hours and recommended action.',                                   caption: 'When 6 teams build the same meeting-summary GPT, that\'s not redundancy. It\'s a proven demand signal. One certified standard replaces all six.' },
          { id: 'recognition',   src: '/ss_recognition.png',   alt: 'Builder Recognition: composite builder scores across quality, adoption, hygiene, and volume. Leaderboard with drill-down per builder.',                                                                caption: 'Know who your best AI builders are. Composite scores across quality, adoption, hygiene, and volume.' },
          { id: 'learning',      src: '/ss_learning.png',      alt: 'Courses: LLM-powered course suggestions per builder based on actual skill gaps detected in their GPT output.',                                                                           caption: 'LLM-recommended training per builder, grounded in actual skill gaps. Not a generic course catalog.' },
          { id: 'workshops',     src: '/ss_workshops.png',     alt: 'Workshops: session management with participant lists, GPT tagging, and time-based quality impact measurement.',                                                                                        caption: 'Track workshops. Tag GPTs. Measure quality improvement before vs after.' },
          { id: 'sync',          src: '/ss_sync.png',          alt: 'Sync: manual sync button, auto-sync toggle, full sync history with token consumption and cost per run.',                                                                                              caption: 'One sync. Three pipelines. Every run ends with a board-ready executive summary and ranked priority actions.' },
          { id: 'employee',      src: '/ss_employee.png',      alt: 'Employee Portal: read-only GPT and Project discovery for the whole org. Search by role, category, or need.',                                                                                          caption: 'Every GPT, discoverable by anyone. Check what already exists before you build.' },
          { id: 'journey',       src: '/ss_journey.png',       alt: 'Asset Journey: longitudinal quality, adoption, and risk score history for a single GPT. Line chart shows how scores evolved across every sync run.',                                                  caption: 'Every asset has a history. Watch quality improve, or catch a regression before it spreads.' },
        ].map((panel, i) => (
          <div data-panel={panel.id} class={`ss-panel ${i !== 0 ? 'hidden' : ''}`}>
            <img
              src={panel.src}
              alt={panel.alt}
              class="w-full h-auto block"
              loading="lazy"
              width="1366"
              height="768"
            />
            <div class="px-5 py-3 bg-bg border-t border-border text-sm text-text-muted font-medium text-center">{panel.caption}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script>
    const tabs = document.querySelectorAll<HTMLButtonElement>('.ss-tab');
    const panels = document.querySelectorAll<HTMLElement>('.ss-panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab;

        tabs.forEach(t => {
          t.classList.remove('border-accent', 'bg-accent/10', 'text-accent');
          t.classList.add('border-border', 'bg-bg', 'text-text-muted');
        });
        tab.classList.add('border-accent', 'bg-accent/10', 'text-accent');
        tab.classList.remove('border-border', 'bg-bg', 'text-text-muted');

        panels.forEach(p => {
          p.classList.toggle('hidden', p.dataset.panel !== target);
        });
      });
    });
  </script>

  <!-- ─── THE PROBLEM ───────────────────────────────────────────── -->
  <section class="py-14 md:py-24 px-4 sm:px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-8 md:mb-14">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">The data is there. The intelligence isn't.</h2>
        <p class="text-text-muted text-lg max-w-2xl mx-auto">
          OpenAI gives enterprise admins full visibility into their workspace. But visibility isn't intelligence, and right now, most leaders are flying blind.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-5">
        {[
          {
            color: 'red',
            title: 'No inventory',
            desc: 'Your OpenAI admin console shows you what exists. Not what\'s dangerous, redundant, or wasted. Hundreds of GPTs and Projects built across the org, with no risk assessment and no quality signal.',
          },
          {
            color: 'amber',
            title: 'No patterns',
            desc: 'You don\'t know who your best AI builders are. Or who needs training. Or which GPTs are doing the same thing. Or which workflows have no AI coverage at all. The data exists. It\'s just unexplored.',
          },
          {
            color: 'accent',
            title: 'No measurement',
            desc: 'What is your ChatGPT Enterprise investment actually producing? Without this, ChatGPT Enterprise is a cost center that can\'t justify renewal.',
          },
        ].map(c => (
          <div class={`p-5 sm:p-7 rounded-2xl border border-border bg-surface hover:border-${c.color}/30 transition-colors`}>
            <h3 class="text-lg font-bold mb-3">{c.title}</h3>
            <p class="text-text-muted text-sm leading-relaxed">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── FEATURES: WHAT YOU GET ────────────────────────────────── -->
  <section id="features" class="py-14 md:py-24 px-4 sm:px-6 bg-surface">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center gap-3 justify-center mb-3">
        <span class="w-2 h-2 rounded-full bg-green animate-pulse"></span>
        <span class="text-xs font-semibold text-green uppercase tracking-wider">Production-ready today</span>
      </div>
      <div class="text-center mb-8 md:mb-14">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Everything leaders need. In one place.</h2>
        <p class="text-text-muted text-lg max-w-xl mx-auto">
          Every Custom GPT and Project in your workspace: discovered, scored, and acted on.
        </p>
      </div>

      <div class="space-y-6">

        <!-- Home: Quadrant + Priority Actions — hero feature -->
        <div class="p-5 sm:p-8 rounded-2xl border border-accent/30 bg-bg">
          <div class="flex items-center gap-3 mb-2">
            <span class="px-3 py-1 rounded-full text-xs font-semibold bg-accent/10 text-accent border border-accent/20">Home</span>
            <span class="text-text-dim text-sm">The first screen. The most important one.</span>
          </div>
          <h3 class="text-xl font-bold mb-3">Quality × Adoption Quadrant + AI Priority Actions</h3>
          <p class="text-text-muted text-sm leading-relaxed mb-5 max-w-3xl">
            Every scored GPT lands in one of four quadrants: <strong class="text-text">Champion</strong> (high quality, high adoption: scale these), <strong class="text-text">Hidden Gem</strong> (high quality, low adoption: promote these), <strong class="text-text">Scaled Risk</strong> (low quality, high adoption: fix these now), <strong class="text-text">Retirement Candidate</strong> (low quality, low adoption: decommission). After every pipeline run, an LLM generates 5-10 ranked priority actions and a board-ready executive summary paragraph, each action tied to specific GPTs with impact, effort, and reasoning.
          </p>
          <div class="grid sm:grid-cols-4 gap-3">
            {[
              { label: 'Champion', color: 'green',  desc: 'High quality · High adoption. Scale and certify.' },
              { label: 'Hidden Gem', color: 'accent', desc: 'High quality · Low adoption. Promote and surface.' },
              { label: 'Scaled Risk', color: 'amber', desc: 'Low quality · High adoption. Fix before it spreads.' },
              { label: 'Retirement Candidate', color: 'red', desc: 'Low quality · Low adoption. Decommission.' },
            ].map(q => (
              <div class={`p-4 rounded-xl border border-${q.color}/20 bg-${q.color}/5`}>
                <div class={`text-${q.color} text-xs font-bold mb-1`}>{q.label}</div>
                <p class="text-text-dim text-xs leading-relaxed">{q.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Portfolio + Adoption -->
        <div class="grid md:grid-cols-2 gap-6">
          <div class="p-5 sm:p-8 rounded-2xl border border-border bg-bg">
            <div class="flex items-center gap-3 mb-2">
              <span class="px-3 py-1 rounded-full text-xs font-semibold bg-accent/10 text-accent border border-accent/20">Portfolio</span>
            </div>
            <h3 class="text-lg font-bold mb-2">Scored. Ranked. Historically tracked.</h3>
            <p class="text-text-muted text-sm leading-relaxed">
              Every asset gets composite <strong class="text-text">quality</strong>, <strong class="text-text">adoption</strong>, and <strong class="text-text">risk</strong> scores (0–100). Tabbed views: all assets, ghost assets (zero usage), risk flags. The drawer "Journey" tab shows how each GPT's scores have changed across every sync. Portfolio health trend tracks whether your AI investment is improving over time.
            </p>
          </div>
          <div class="p-5 sm:p-8 rounded-2xl border border-border bg-bg">
            <div class="flex items-center gap-3 mb-2">
              <span class="px-3 py-1 rounded-full text-xs font-semibold bg-accent/10 text-accent border border-accent/20">Adoption</span>
            </div>
            <h3 class="text-lg font-bold mb-2">Conversation intelligence.</h3>
            <p class="text-text-muted text-sm leading-relaxed">
              Syncs the conversation JSONL export from OpenAI to answer: which GPTs are actually being used, by whom, and for what topics. Conversations are attributed back to the originating GPT or Project via the conversation pipeline, giving each asset its own usage fingerprint. Surfaces <strong class="text-text">ghost assets</strong> (built but unused), <strong class="text-text">drift alerts</strong> (usage patterns shifting), <strong class="text-text">knowledge gaps</strong> (conversation topics with no asset match), and per-user adoption scores with role fit analysis.
            </p>
          </div>
        </div>

        <!-- Workflows — new feature, full width -->
        <div class="p-5 sm:p-8 rounded-2xl border border-violet/30 bg-bg">
          <div class="flex items-center gap-3 mb-2">
            <span class="px-3 py-1 rounded-full text-xs font-semibold bg-violet/10 text-violet border border-violet/20">Workflows</span>
            <span class="text-text-dim text-sm">Where should we build AI next?</span>
          </div>
          <h3 class="text-xl font-bold mb-3">Business process coverage analysis.</h3>
          <p class="text-text-muted text-sm leading-relaxed mb-5 max-w-3xl">
            Maps every conversation and GPT to the business processes they touch. After each sync, the platform categorizes every workflow into one of three states and generates LLM reasoning and a recommended action for each.
          </p>
          <div class="grid sm:grid-cols-3 gap-3">
            {[
              { label: 'Covered',       color: 'green',  desc: 'Assets built + active conversations. Healthy. Monitor for drift.' },
              { label: 'Ghost Coverage', color: 'amber', desc: 'Assets built, but zero conversation activity. Nobody\'s using it.' },
              { label: 'Intent Gap',    color: 'violet', desc: 'Conversation demand exists, but no dedicated asset. Build this next.' },
            ].map(w => (
              <div class={`p-4 rounded-xl border border-${w.color}/20 bg-${w.color}/5`}>
                <div class={`text-${w.color} text-xs font-bold mb-1`}>{w.label}</div>
                <p class="text-text-dim text-xs leading-relaxed">{w.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Build Signals + L&D row -->
        <div class="grid md:grid-cols-2 gap-6">
          <div class="p-5 sm:p-8 rounded-2xl border border-border bg-bg">
            <div class="flex items-center gap-3 mb-2">
              <span class="px-3 py-1 rounded-full text-xs font-semibold bg-accent/10 text-accent border border-accent/20">Build Signals</span>
            </div>
            <h3 class="text-lg font-bold mb-2">Proven demand. Not just redundancy.</h3>
            <p class="text-text-muted text-sm leading-relaxed">
              Semantic clustering (pgvector + centroid algorithm + LLM validation) detects when multiple teams independently built GPTs for the same workflow. That convergence is a strong demand signal. Surfaces the best-candidate asset to certify as an org standard, with estimated hours saved by consolidation.
            </p>
          </div>
          <div class="p-5 sm:p-8 rounded-2xl border border-border bg-bg">
            <div class="flex items-center gap-3 mb-2">
              <span class="px-3 py-1 rounded-full text-xs font-semibold bg-green/10 text-green border border-green/20">Learning & Dev</span>
            </div>
            <h3 class="text-lg font-bold mb-2">Recognition. Courses. Workshops.</h3>
            <p class="text-text-muted text-sm leading-relaxed">
              <strong class="text-text">Recognition:</strong> composite builder scores across quality, adoption, hygiene, and volume. Know who to promote and who to support. <strong class="text-text">Learning:</strong> LLM-recommended courses per builder, grounded in actual skill gaps in their GPT output, not a generic catalog. <strong class="text-text">Workshops:</strong> track sessions, participants, GPT tagging, and measure quality improvement before vs after.
            </p>
          </div>
        </div>

        <!-- Security row -->
        <div class="p-5 sm:p-8 rounded-2xl border border-red/20 bg-bg">
          <div class="flex items-center gap-3 mb-2">
            <span class="px-3 py-1 rounded-full text-xs font-semibold bg-red/10 text-red border border-red/20">Security</span>
            <span class="text-text-dim text-sm">Enterprise-grade auth out of the box.</span>
          </div>
          <h3 class="text-xl font-bold mb-3">SSO · TOTP MFA · Role-gated access · Encrypted secrets</h3>
          <div class="grid sm:grid-cols-4 gap-3">
            {[

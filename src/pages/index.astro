---
import Base from '../layouts/Base.astro';

// What the Compliance API actually exposes — the full surface
const apiSurface = [
  { name: 'Custom GPTs', phase: 1, icon: '🤖' },
  { name: 'Projects', phase: 2, icon: '📁' },
  { name: 'Conversations', phase: 2, icon: '💬' },
  { name: 'Users & Behavior', phase: 2, icon: '👥' },
  { name: 'Automations', phase: 3, icon: '⚡' },
  { name: 'Canvases', phase: 3, icon: '🎨' },
  { name: 'Memories', phase: 3, icon: '🧠' },
  { name: 'Recordings', phase: 3, icon: '🎙️' },
  { name: 'Compliance Logs', phase: 2, icon: '📋' },
  { name: 'Codex Environments', phase: 3, icon: '💻' },
];

const faqs = [
  {
    q: 'Is this affiliated with OpenAI?',
    a: 'No. Independent open-source project. Integrates with OpenAI\'s Compliance API, GPT API, and Embeddings API — not endorsed by OpenAI.',
  },
  {
    q: 'Does my data leave my infrastructure?',
    a: 'Never. Fully self-hosted on your own PostgreSQL instance. API keys are Fernet-encrypted at rest.',
  },
  {
    q: 'What do I need to get started?',
    a: 'Docker Desktop. Clone the repo, run make up, and you\'re live at localhost:3000 in under 5 minutes. Demo mode works without any API key.',
  },
  {
    q: 'Is Phase 1 (GPT governance) production-ready today?',
    a: 'Yes. Discovery via Compliance API, 9-KPI semantic enrichment, risk flagging, duplicate detection, builder L&D, and demo mode are all fully built and running.',
  },
  {
    q: 'How is this different from the OpenAI admin console?',
    a: 'The admin console is a management interface. AgentsOrg is an intelligence layer — it enriches, scores, clusters, and surfaces patterns across everything the Compliance API exposes. Different purpose entirely.',
  },
  {
    q: 'Can I use this commercially?',
    a: 'Yes. Apache 2.0 — free for any use including production and commercial deployments.',
  },
];
---

<Base
  title="AgentsOrg — AI Transformation Intelligence for Enterprise ChatGPT"
  description="The open-source intelligence layer for enterprise ChatGPT. Built on OpenAI's Compliance API. Start with GPT governance. Expand to full enterprise AI intelligence."
>

  <!-- ─── HERO ─────────────────────────────────────────────────── -->
  <section class="pt-24 md:pt-32 pb-16 md:pb-24 px-4 sm:px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-accent/[0.07] via-transparent to-transparent pointer-events-none"></div>
    <div class="absolute top-32 left-1/2 -translate-x-1/2 w-[1000px] h-[500px] bg-accent/[0.04] rounded-full blur-[160px] pointer-events-none"></div>

    <div class="max-w-4xl mx-auto text-center relative">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-border bg-surface text-xs text-text-muted mb-8 animate-fade-in">
        <span class="w-2 h-2 rounded-full bg-green animate-pulse"></span>
        Open Source &middot; Apache 2.0 &middot; Built on OpenAI's Compliance API
      </div>

      <h1 class="text-4xl sm:text-5xl md:text-[4.5rem] font-black tracking-tight leading-[1.05] mb-7 animate-fade-in animate-delay-1">
        The intelligence layer<br/>
        <span class="bg-gradient-to-r from-accent via-accent-2 to-violet bg-clip-text text-transparent">for enterprise ChatGPT.</span>
      </h1>

      <p class="text-lg md:text-2xl text-text-muted max-w-2xl mx-auto mb-4 animate-fade-in animate-delay-2 leading-relaxed">
        OpenAI's Compliance API exposes the full digital exhaust of your enterprise AI deployment. AgentsOrg turns that data into intelligence AI leaders can act on.
      </p>

      <p class="text-base text-text-dim max-w-xl mx-auto mb-10 animate-fade-in animate-delay-2">
        Phase 1 — Custom GPT governance — is live today. The platform is built to expand across every data source the API exposes.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16 animate-fade-in animate-delay-3">
        <a
          href="https://github.com/ori129/agentsorg"
          target="_blank"
          class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl bg-accent text-white font-semibold hover:bg-accent/90 transition-all hover:shadow-xl hover:shadow-accent/25 text-sm"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          View on GitHub
        </a>
        <a
          href="https://github.com/ori129/agentsorg#quick-start"
          target="_blank"
          class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl border border-border bg-surface text-text font-semibold hover:border-accent/40 transition-all text-sm"
        >
          Try Demo — no API key needed
        </a>
      </div>

      <!-- Compliance API surface map -->
      <div class="max-w-3xl mx-auto animate-fade-in animate-delay-4">
        <div class="text-xs text-text-dim uppercase tracking-wider mb-4">OpenAI Compliance API — data sources AgentsOrg is built to cover</div>
        <div class="flex flex-wrap justify-center gap-2">
          {apiSurface.map(s => (
            <span class={`px-3 py-1.5 rounded-full text-xs border flex items-center gap-1.5 ${
              s.phase === 1
                ? 'border-accent/40 bg-accent/10 text-accent'
                : s.phase === 2
                ? 'border-violet/30 bg-violet/5 text-violet'
                : 'border-border bg-surface text-text-dim'
            }`}>
              {s.icon} {s.name}
              {s.phase === 1 && <span class="text-accent/60">✓</span>}
            </span>
          ))}
        </div>
        <div class="flex items-center justify-center gap-6 mt-4 text-xs text-text-dim">
          <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-accent inline-block"></span>Phase 1 — live</span>
          <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-violet inline-block"></span>Phase 2 — coming</span>
          <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-border inline-block"></span>Phase 3 — vision</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── THE PROBLEM ───────────────────────────────────────────── -->
  <section class="py-14 md:py-24 px-4 sm:px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-8 md:mb-14">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">The data is there. The intelligence isn't.</h2>
        <p class="text-text-muted text-lg max-w-2xl mx-auto">
          OpenAI gives enterprise leaders a Compliance API with full visibility into their workspace. Nobody has built the intelligence layer on top of it. Until now.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-5">
        {[
          {
            color: 'red',
            title: 'No inventory',
            desc: 'Hundreds of Custom GPTs, Projects, and automations built across the org. No central view. No risk assessment. No quality signal.',
          },
          {
            color: 'amber',
            title: 'No patterns',
            desc: 'Who are your best AI builders? Which GPTs are duplicates? Where is training needed? The data exists — it\'s just unexplored.',
          },
          {
            color: 'accent',
            title: 'No measurement',
            desc: 'What is your ChatGPT Enterprise investment actually producing? Without intelligence, there\'s no answer — just spend.',
          },
        ].map(c => (
          <div class={`p-5 sm:p-7 rounded-2xl border border-border bg-surface hover:border-${c.color}/30 transition-colors`}>
            <h3 class="text-lg font-bold mb-3">{c.title}</h3>
            <p class="text-text-muted text-sm leading-relaxed">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── PHASE 1: WHAT'S LIVE ──────────────────────────────────── -->
  <section id="features" class="py-14 md:py-24 px-4 sm:px-6 bg-surface">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center gap-3 justify-center mb-3">
        <span class="w-2 h-2 rounded-full bg-green animate-pulse"></span>
        <span class="text-xs font-semibold text-green uppercase tracking-wider">Phase 1 — Live Today</span>
      </div>
      <div class="text-center mb-8 md:mb-14">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Custom GPT Governance</h2>
        <p class="text-text-muted text-lg max-w-xl mx-auto">
          The first intelligence module. Every Custom GPT in your workspace — discovered, scored, and acted on.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <!-- Leader Dashboard -->
        <div class="md:col-span-2 p-5 sm:p-8 rounded-2xl border border-accent/20 bg-bg">
          <div class="flex items-center gap-3 mb-6">
            <span class="px-3 py-1 rounded-full text-xs font-semibold bg-accent/10 text-accent border border-accent/20">Leader Dashboard</span>
            <span class="text-text-dim text-sm">ai-leader and system-admin roles</span>
          </div>
          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
            {[
              { name: 'Overview', color: 'accent', desc: 'Portfolio KPIs, creation velocity, drill-downs by builder, department, maturity, business process, output type.' },
              { name: 'Risk Panel', color: 'red', desc: 'Every GPT flagged by severity. Data exposure, compliance gaps, ungoverned builds — surfaced automatically.' },
              { name: 'Duplicates', color: 'violet', desc: 'pgvector semantic clustering finds GPTs solving the same problem, even when named completely differently.' },
              { name: 'Quality Scores', color: 'amber', desc: 'Prompting quality distribution across the portfolio. See the gap between your best and weakest builders.' },
            ].map(item => (
              <div class={`p-5 rounded-xl border border-border bg-surface hover:border-${item.color}/30 transition-colors`}>
                <div class={`text-${item.color} text-xs font-semibold mb-2`}>{item.name}</div>
                <p class="text-text-muted text-xs leading-relaxed">{item.desc}</p>
              </div>
            ))}
          </div>
          <div class="grid sm:grid-cols-3 gap-4">
            {[
              { name: 'Recognition', color: 'green', desc: 'Composite builder scores: quality 35% · adoption 25% · hygiene 25% · volume 15%.' },
              { name: 'Learning', color: 'green', desc: 'LLM recommends OpenAI Academy courses per builder based on actual KPI gaps — not generic training.' },
              { name: 'Workshops', color: 'green', desc: 'Track in-person sessions. Participant lists. GPT tagging. Measure quality improvement before vs after.' },
            ].map(item => (
              <div class={`p-5 rounded-xl border border-border bg-surface hover:border-${item.color}/30 transition-colors`}>
                <div class={`text-${item.color} text-xs font-semibold mb-2`}>{item.name}</div>
                <p class="text-text-muted text-xs leading-relaxed">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Employee Portal -->
        <div class="p-5 sm:p-8 rounded-2xl border border-border bg-bg">
          <div class="flex items-center gap-3 mb-4">
            <span class="px-3 py-1 rounded-full text-xs font-semibold bg-green/10 text-green border border-green/20">Employee Portal</span>
            <span class="text-text-dim text-sm">All users</span>
          </div>
          <p class="text-text-muted text-sm leading-relaxed">
            Read-only GPT discovery for the entire org. Find what already exists instead of building another duplicate.
          </p>
        </div>

        <!-- 9 KPIs -->
        <div class="p-5 sm:p-8 rounded-2xl border border-border bg-bg">
          <div class="text-xs text-text-dim uppercase tracking-wider mb-4">9 Semantic KPIs — scored per GPT by LLM</div>
          <div class="flex flex-wrap gap-2">
            {['Risk Level', 'Prompting Quality', 'ROI Potential', 'Sophistication', 'Business Process', 'Intended Audience', 'Integrations', 'Output Type', 'Adoption Friction'].map(kpi => (
              <span class="px-2.5 py-1 rounded-full text-xs border border-border bg-surface text-text-muted">{kpi}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── HOW IT WORKS ──────────────────────────────────────────── -->
  <section id="how-it-works" class="py-14 md:py-24 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-8 md:mb-14">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Up and running in minutes</h2>
        <p class="text-text-muted text-lg">Self-hosted. One command. Your data stays on your infrastructure.</p>
      </div>

      <div class="space-y-4">
        {[
          {
            num: '01',
            title: 'Clone & deploy',
            code: 'git clone https://github.com/ori129/agentsorg.git\ncd agentsorg && make up',
            desc: 'Three Docker containers. Postgres with pgvector, FastAPI backend, React frontend. Everything wired up.',
          },
          {
            num: '02',
            title: 'Connect your workspace',
            desc: 'Enter your OpenAI Compliance API key in the setup wizard. Or switch on Demo mode — no API key needed to explore the full platform.',
          },
          {
            num: '03',
            title: 'Run the pipeline',
            desc: 'Fetch → Filter → Classify → Enrich → Embed → Store. Every GPT scored across 9 dimensions. Duplicates clustered. Risk flagged. Progress shown live.',
          },
          {
            num: '04',
            title: 'Act on intelligence',
            desc: 'Leader Dashboard gives you the full picture. Employee Portal gives the org a place to discover what already exists.',
          },
        ].map(s => (
          <div class="flex gap-4 sm:gap-6 p-5 sm:p-7 rounded-2xl border border-border bg-surface hover:border-accent/30 transition-all group">
            <span class="text-3xl font-black text-border group-hover:text-accent/30 transition-colors shrink-0 w-12 text-right">{s.num}</span>
            <div class="flex-1 min-w-0">
              <h3 class="text-lg font-bold mb-2">{s.title}</h3>
              {s.code && (
                <div class="font-mono text-xs bg-bg border border-border rounded-lg p-3 mb-3 text-text-muted whitespace-pre overflow-x-auto max-w-full">{s.code}</div>
              )}
              <p class="text-text-muted text-sm leading-relaxed">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── ROADMAP ───────────────────────────────────────────────── -->
  <section id="roadmap" class="py-14 md:py-24 px-4 sm:px-6 bg-surface">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-8 md:mb-14">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Expanding across the Compliance API</h2>
        <p class="text-text-muted text-lg max-w-2xl mx-auto">
          Each phase unlocks a new data source from OpenAI's Compliance API — adding a new intelligence layer on top of the same foundation.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-5">
        <!-- Phase 1 -->
        <div class="p-5 sm:p-7 rounded-2xl border border-accent/40 bg-bg">
          <div class="flex items-center gap-2 mb-2">
            <span class="w-2 h-2 rounded-full bg-green animate-pulse"></span>
            <span class="text-xs font-semibold text-green uppercase tracking-wider">Phase 1 — Live</span>
          </div>
          <h3 class="text-lg font-bold mb-1">Custom GPT Intelligence</h3>
          <p class="text-text-dim text-xs mb-5">API sources: GPTs · GPT Configs · GPT Files</p>
          <ul class="space-y-2">
            {[
              'Discovery via Compliance API',
              '9-KPI semantic enrichment',
              'Risk flagging & compliance scoring',
              'Duplicate detection via pgvector',
              'Builder recognition & scoring',
              'OpenAI Academy L&D recommendations',
              'Workshop tracking & impact measurement',
              'Demo mode — no API key needed',
            ].map(item => (
              <li class="flex items-start gap-2 text-sm text-text-muted">
                <svg class="w-4 h-4 text-green mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Phase 2 -->
        <div class="p-5 sm:p-7 rounded-2xl border border-border bg-bg">
          <div class="flex items-center gap-2 mb-2">
            <span class="w-2 h-2 rounded-full bg-violet"></span>
            <span class="text-xs font-semibold text-violet uppercase tracking-wider">Phase 2 — Coming</span>
          </div>
          <h3 class="text-lg font-bold mb-1">Usage & People Intelligence</h3>
          <p class="text-text-dim text-xs mb-5">API sources: Projects · Conversations · Users · Logs</p>
          <ul class="space-y-2">
            {[
              'Conversation analytics (volume, patterns)',
              'User-level AI adoption scoring',
              'Department & role benchmarking',
              'Cost attribution per GPT',
              'Compliance log analysis',
              'Automated portfolio health reports',
              'GPT lifecycle tracking',
            ].map(item => (
              <li class="flex items-start gap-2 text-sm text-text-muted">
                <svg class="w-4 h-4 text-text-dim mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Phase 3 -->
        <div class="p-5 sm:p-7 rounded-2xl border border-border bg-bg">
          <div class="flex items-center gap-2 mb-2">
            <span class="w-2 h-2 rounded-full bg-text-dim"></span>
            <span class="text-xs font-semibold text-text-dim uppercase tracking-wider">Phase 3 — Vision</span>
          </div>
          <h3 class="text-lg font-bold mb-1">Full AI Work Surface</h3>
          <p class="text-text-dim text-xs mb-5">API sources: Automations · Canvases · Memories · Recordings · Codex</p>
          <ul class="space-y-2">
            {[
              'Automation governance & audit',
              'Canvas knowledge mapping',
              'Memory footprint analysis',
              'Recording transcript intelligence',
              'Codex task analytics',
              'Cross-source AI maturity score',
              'Executive board-ready reporting',
            ].map(item => (
              <li class="flex items-start gap-2 text-sm text-text-dim">
                <svg class="w-4 h-4 text-text-dim/40 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── ADVISORS CTA ──────────────────────────────────────────── -->
  <section class="py-14 md:py-24 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto">
      <div class="p-7 sm:p-12 rounded-3xl border border-accent/20 bg-gradient-to-br from-accent/5 via-surface to-accent-2/5 relative overflow-hidden text-center">
        <div class="absolute top-0 right-0 w-72 h-72 bg-accent/5 rounded-full blur-[120px] pointer-events-none"></div>
        <h2 class="text-3xl md:text-4xl font-bold mb-4 relative">AI Transformation Advisors</h2>
        <p class="text-text-muted text-base sm:text-lg mb-6 sm:mb-8 max-w-xl mx-auto relative leading-relaxed">
          Use AgentsOrg as your client assessment toolkit. Run a GPT portfolio audit in minutes. Get listed in our directory of 50+ advisors.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 relative">
          <a href="/advisors" class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl bg-accent text-white font-semibold hover:bg-accent/90 transition-all text-sm">
            View Advisor Directory
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
          <a href="/advisors#apply" class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl border border-border bg-surface text-text font-semibold hover:border-accent/50 transition-all text-sm">
            Apply to Join
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── OPEN SOURCE ───────────────────────────────────────────── -->
  <section class="py-10 md:py-16 px-4 sm:px-6 bg-surface">
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-3 gap-5">
        <a href="https://github.com/ori129/agentsorg/blob/main/CONTRIBUTING.md" target="_blank"
          class="p-5 sm:p-7 rounded-2xl border border-border bg-bg hover:border-accent/30 transition-all group text-center">
          <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
          </div>
          <h3 class="font-semibold mb-2 group-hover:text-accent transition-colors">Contribute</h3>
          <p class="text-text-muted text-sm">PRs welcome. Apache 2.0. Each new phase is a contribution opportunity.</p>
        </a>
        <a href="https://github.com/ori129/agentsorg/discussions" target="_blank"
          class="p-5 sm:p-7 rounded-2xl border border-border bg-bg hover:border-accent/30 transition-all group text-center">
          <div class="w-10 h-10 rounded-xl bg-violet/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-5 h-5 text-violet" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          </div>
          <h3 class="font-semibold mb-2 group-hover:text-violet transition-colors">Discuss</h3>
          <p class="text-text-muted text-sm">Shape the roadmap. Questions, ideas, and show & tell.</p>
        </a>
        <a href="https://github.com/ori129/agentsorg/issues" target="_blank"
          class="p-5 sm:p-7 rounded-2xl border border-border bg-bg hover:border-accent/30 transition-all group text-center">
          <div class="w-10 h-10 rounded-xl bg-amber/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-5 h-5 text-amber" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="font-semibold mb-2 group-hover:text-amber transition-colors">Report a Bug</h3>
          <p class="text-text-muted text-sm">We respond within 48 hours.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ─── FAQ ──────────────────────────────────────────────────── -->
  <section class="py-14 md:py-24 px-4 sm:px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-bold mb-6 md:mb-10 text-center">FAQ</h2>
      <div class="space-y-3">
        {faqs.map(faq => (
          <details class="group p-4 sm:p-6 rounded-2xl border border-border bg-surface hover:border-accent/30 transition-colors">

---
import Base from '../layouts/Base.astro';
import { advisors } from '../data/advisors.ts';

const featured = advisors.filter(a => a.featured);
const rest = advisors.filter(a => !a.featured);

const FORM_ACTION = "https://formsubmit.co/ori129@gmail.com";
const REDIRECT_URL = "https://agentsorg.ai/apply-thanks";
---

<Base
  title="AI Transformation Advisors Directory — AgentsOrg"
  description="50+ AI Transformation Advisors helping enterprises govern and optimize their ChatGPT Enterprise deployment. Find an advisor or apply to join."
>
  <!-- Hero -->
  <section class="pt-32 pb-20 px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-accent-2/5 via-transparent to-transparent pointer-events-none"></div>
    <div class="max-w-5xl mx-auto text-center relative">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-border bg-surface text-xs text-text-muted mb-8">
        <span class="w-2 h-2 rounded-full bg-green animate-pulse"></span>
        {advisors.length} Advisors Listed &middot; Accepting Applications
      </div>
      <h1 class="text-5xl md:text-6xl font-black tracking-tight mb-6">
        AI Transformation<br />
        <span class="bg-gradient-to-r from-accent to-accent-2 bg-clip-text text-transparent">Advisors</span>
      </h1>
      <p class="text-xl text-text-muted max-w-3xl mx-auto mb-10 leading-relaxed">
        Trusted consultants helping enterprises govern and optimize their ChatGPT investment.
        Use AgentsOrg as your assessment toolkit. Deliver GPT portfolio audits in minutes.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#apply" class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl bg-accent text-white font-semibold hover:bg-accent/90 transition-all hover:shadow-lg hover:shadow-accent/20">
          Apply to Join
        </a>
        <a href="#directory" class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl border border-border bg-surface text-text font-semibold hover:border-accent/50 transition-all">
          Browse {advisors.length} Advisors
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Directory -->
  <section id="directory" class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Advisor Directory</h2>
        <p class="text-text-muted text-lg">Leading practitioners in AI transformation, governance, and ChatGPT Enterprise adoption.</p>
      </div>

      <!-- Featured -->
      {featured.length > 0 && (
        <div class="grid md:grid-cols-2 gap-6 mb-6">
          {featured.map((a) => (
            <a href={a.url} target="_blank" rel="noopener noreferrer"
              class="p-8 rounded-2xl border border-accent/20 bg-surface hover:border-accent/50 transition-all group block">
              <div class="flex items-start justify-between gap-4 mb-4">
                <div>
                  <h3 class="text-xl font-bold group-hover:text-accent transition-colors">{a.name}</h3>
                  <p class="text-text-muted text-sm mt-0.5">{a.role}</p>
                  <p class="text-text-dim text-xs">{a.firm}</p>
                </div>
                <div class="flex flex-col items-end gap-2 shrink-0">
                  <span class="px-2 py-1 rounded-full text-xs bg-accent/10 text-accent border border-accent/20">Featured</span>
                  <span class="text-text-dim text-xs">{a.region}</span>
                </div>
              </div>
              <span class="inline-block px-3 py-1 rounded-full text-xs bg-surface-2 text-text-muted border border-border mb-4">{a.specialization}</span>
              <p class="text-text-muted text-sm leading-relaxed">{a.bio}</p>
              <div class="mt-4 flex items-center gap-1 text-accent text-sm font-medium">
                Visit Profile
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              </div>
            </a>
          ))}
        </div>
      )}

      <!-- Full grid -->
      <div class="grid md:grid-cols-3 gap-5">
        {rest.map((a) => (
          <a href={a.url} target="_blank" rel="noopener noreferrer"
            class="p-6 rounded-2xl border border-border bg-surface hover:border-accent/30 transition-all group block">
            <div class="mb-3">
              <h3 class="text-base font-bold group-hover:text-accent transition-colors leading-tight">{a.name}</h3>
              <p class="text-text-muted text-xs mt-0.5">{a.role}</p>
              <p class="text-text-dim text-xs">{a.firm}</p>
            </div>
            <span class="inline-block px-2 py-0.5 rounded-full text-xs bg-surface-2 text-text-muted border border-border mb-3">{a.specialization}</span>
            <p class="text-text-muted text-xs leading-relaxed line-clamp-3">{a.bio}</p>
            <div class="mt-3 flex items-center justify-between">
              <span class="text-text-dim text-xs">{a.region}</span>
              <span class="text-accent text-xs font-medium flex items-center gap-1">
                Profile
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              </span>
            </div>
          </a>
        ))}
        <!-- Open slot -->
        <div class="p-6 rounded-2xl border border-dashed border-border bg-surface/30 flex flex-col items-center justify-center text-center min-h-[180px]">
          <svg class="w-8 h-8 text-text-dim mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
          <p class="text-text-dim text-sm mb-2">Your profile here</p>
          <a href="#apply" class="text-accent text-sm font-medium hover:underline">Apply to Join</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why join -->
  <section class="py-24 px-6 bg-surface">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Why Advisors Choose AgentsOrg</h2>
        <p class="text-text-muted text-lg max-w-2xl mx-auto">Stop building one-off assessment spreadsheets. Deliver enterprise GPT governance engagements at scale.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {[
          { color: 'accent', title: 'Instant Portfolio Assessment', desc: 'Deploy AgentsOrg for any client and produce a comprehensive GPT portfolio audit in minutes — 9 semantic KPIs per GPT, risk flagging, duplicate detection, and maturity analysis.' },
          { color: 'green', title: 'Data-Driven Recommendations', desc: 'Move from opinion-based to evidence-based consulting. Show clients exactly where their AI maturity gaps are, which GPTs are risky, and where to invest.' },
          { color: 'violet', title: 'Directory Listing & Leads', desc: 'Get listed alongside the world\'s leading AI transformation practitioners. Enterprises searching for help find you through agentsorg.ai.' },
          { color: 'amber', title: 'Shared Methodology', desc: 'Use the AI Transformation Intelligence framework, GPT Portfolio Maturity Model, and governance playbook. Deliver consistent, high-quality engagements.' },
        ].map(b => (
          <div class="p-8 rounded-2xl border border-border bg-bg hover:border-accent/30 transition-all">
            <h3 class="text-lg font-semibold mb-3">{b.title}</h3>
            <p class="text-text-muted text-sm leading-relaxed">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Application Form -->
  <section id="apply" class="py-24 px-6">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Apply to Join the Directory</h2>
        <p class="text-text-muted text-lg">Tell us about your practice. Applications reviewed weekly.</p>
      </div>

      <form action={FORM_ACTION} method="POST" class="p-8 rounded-2xl border border-border bg-surface space-y-5">
        <!-- Formsubmit.co config -->
        <input type="hidden" name="_subject" value="New AgentsOrg Advisor Application" />
        <input type="hidden" name="_next" value={REDIRECT_URL} />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_template" value="table" />

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-medium mb-2">Full Name *</label>
            <input type="text" name="name" required placeholder="Jane Smith"
              class="w-full px-4 py-2.5 rounded-lg border border-border bg-bg text-text placeholder-text-dim focus:outline-none focus:border-accent transition-colors text-sm" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-2">Firm / Company *</label>
            <input type="text" name="firm" required placeholder="Acme AI Consulting"
              class="w-full px-4 py-2.5 rounded-lg border border-border bg-bg text-text placeholder-text-dim focus:outline-none focus:border-accent transition-colors text-sm" />
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-medium mb-2">Role / Title *</label>
            <input type="text" name="role" required placeholder="Founder & AI Advisor"
              class="w-full px-4 py-2.5 rounded-lg border border-border bg-bg text-text placeholder-text-dim focus:outline-none focus:border-accent transition-colors text-sm" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-2">Specialization *</label>
            <input type="text" name="specialization" required placeholder="Enterprise AI Governance"
              class="w-full px-4 py-2.5 rounded-lg border border-border bg-bg text-text placeholder-text-dim focus:outline-none focus:border-accent transition-colors text-sm" />
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-medium mb-2">Region *</label>
            <select name="region" required
              class="w-full px-4 py-2.5 rounded-lg border border-border bg-bg text-text focus:outline-none focus:border-accent transition-colors text-sm">
              <option value="">Select region...</option>
              <option>Northeast US</option>
              <option>Southeast US</option>
              <option>Midwest US</option>
              <option>Southwest US</option>
              <option>West Coast</option>
              <option>Global</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium mb-2">Website or LinkedIn *</label>
            <input type="url" name="url" required placeholder="https://yoursite.com"
              class="w-full px-4 py-2.5 rounded-lg border border-border bg-bg text-text placeholder-text-dim focus:outline-none focus:border-accent transition-colors text-sm" />
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium mb-2">Short Bio * <span class="text-text-dim font-normal">(2 sentences max)</span></label>
          <textarea name="bio" required rows="3" placeholder="What you do and your most notable credential..."
            class="w-full px-4 py-2.5 rounded-lg border border-border bg-bg text-text placeholder-text-dim focus:outline-none focus:border-accent transition-colors text-sm resize-none"></textarea>
        </div>

        <div>
          <label class="block text-sm font-medium mb-2">How would you use AgentsOrg with clients?</label>
          <textarea name="message" rows="3" placeholder="e.g. GPT portfolio audits during discovery, ongoing governance assessments..."
            class="w-full px-4 py-2.5 rounded-lg border border-border bg-bg text-text placeholder-text-dim focus:outline-none focus:border-accent transition-colors text-sm resize-none"></textarea>
        </div>

        <button type="submit"
          class="w-full py-3.5 rounded-xl bg-accent text-white font-semibold hover:bg-accent/90 transition-all hover:shadow-lg hover:shadow-accent/20">
          Submit Application
        </button>
        <p class="text-text-dim text-xs text-center">We review applications weekly and reply within a few days.</p>
      </form>
    </div>
  </section>
</Base>
